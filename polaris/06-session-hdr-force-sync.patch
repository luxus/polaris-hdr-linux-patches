From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: patch-rebuild <patches@local>
Date: Wed, 15 Jul 2026 11:30:00 +0200
Subject: [PATCH] topic6: sync polaris-hdr-force (no gamescope restart)

Write polaris-hdr-force for portal is_hdr only. Do not restart idle
gamescope from process/video probe (encoder probes thrash HDR flags).
---
--- a/src/process.cpp	2026-07-13 02:15:49.000000000 +0200
+++ b/src/process.cpp
@@ -2449,6 +2449,34 @@
       launch_session->enable_hdr = *resolved_optimization.hdr;
     }
 
+#ifdef __linux__
+    // Sync portal is_hdr gate only. Do NOT restart gamescope here — encoder
+    // probe calls this path with dynamicRange 0 and 1 and would thrash idle
+    // (visible flicker). polaris-hdr-session owns idle restart on session start.
+    {
+      const char *rt = std::getenv("XDG_RUNTIME_DIR");
+      if (rt && *rt) {
+        const auto force_path = std::filesystem::path(rt) / "polaris-hdr-force";
+        std::string prev;
+        {
+          std::ifstream in(force_path);
+          std::getline(in, prev);
+          while (!prev.empty() && (prev.back() == '\r' || prev.back() == '\n' || prev.back() == ' ')) {
+            prev.pop_back();
+          }
+        }
+        const std::string want = launch_session->enable_hdr ? "1" : "0";
+        if (prev != want) {
+          std::ofstream out(force_path, std::ios::trunc);
+          out << want << '\n';
+          BOOST_LOG(info) << "portal HDR force -> "sv << want << " (was \""sv << prev
+                          << "\") from enable_hdr="sv
+                          << (launch_session->enable_hdr ? "true"sv : "false"sv);
+        }
+      }
+    }
+#endif
+
     if (resolved_optimization.virtual_display.has_value()) {
       launch_session->virtual_display = *resolved_optimization.virtual_display;
     }
--- a/src/video.cpp	2026-07-15 11:18:29.906225747 +0200
+++ b/src/video.cpp
@@ -7,6 +7,7 @@
 #include <atomic>
 #include <bitset>
 #include <cmath>
+#include <cstdlib>
 #include <filesystem>
 #include <fcntl.h>
 #include <fstream>
@@ -524,6 +525,36 @@
 
     hdr_probe_t probe_display_hdr(platf::display_t &disp, const config_t &config) {
       hdr_probe_t probe;
+
+#ifdef __linux__
+      // Align force file with stream dynamicRange for portal is_hdr/metadata.
+      // Never systemctl-restart gamescope from probe — capability probes flip
+      // dynamicRange 0/1 repeatedly and restarting idle caused stream flicker.
+      {
+        const char *rt = std::getenv("XDG_RUNTIME_DIR");
+        if (rt && *rt) {
+          const auto force_path = std::filesystem::path(rt) / "polaris-hdr-force";
+          const bool want_on = config.dynamicRange > 0;
+          std::string prev;
+          {
+            std::ifstream in(force_path);
+            std::getline(in, prev);
+            while (!prev.empty() && (prev.back() == '\r' || prev.back() == '\n' || prev.back() == ' ')) {
+              prev.pop_back();
+            }
+          }
+          const bool prev_on = (prev == "1" || prev == "true");
+          if (prev_on != want_on) {
+            std::ofstream out(force_path, std::ios::trunc);
+            out << (want_on ? "1" : "0") << '\n';
+            BOOST_LOG(info) << "portal HDR force -> "sv << (want_on ? "1"sv : "0"sv)
+                            << " from stream dynamicRange="sv << config.dynamicRange
+                            << " (was \""sv << prev << "\"; no idle restart)"sv;
+          }
+        }
+      }
+#endif
+
       probe.display_hdr = disp.is_hdr();
 
       if (config.dynamicRange > 0 && probe.display_hdr) {

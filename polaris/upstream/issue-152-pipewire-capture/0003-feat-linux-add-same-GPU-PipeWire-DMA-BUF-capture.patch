+TEST(PipeWireCapturePolicyTests, SameRenderNodeEligibilityRequiresExplicitMatchingGpuPathAndEglSupport) {
+  const pipewire_capture::dmabuf_eligibility_t eligible {
+    .capture_render_node = "/dev/dri/renderD128",

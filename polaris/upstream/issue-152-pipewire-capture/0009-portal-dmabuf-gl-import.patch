+  std::optional<rgb_t> import_source(display_t::pointer egl_display, const surface_descriptor_t &xrgb) {
+    // gamescope linear BGRx often arrives as modifier 0 / INVALID; NVIDIA can reject
+    // the first fourcc+modifier combo with GL_INVALID_OPERATION on TargetTexture2D.
+    // Try a small matrix of import shapes before giving up (SHM fallback elsewhere).
+    surface_descriptor_t variants[6] = {xrgb, xrgb, xrgb, xrgb, xrgb, xrgb};
+
+    // 0: as-is with modifiers
+    // 1: force LINEAR modifier
+    variants[1].modifier = DRM_FORMAT_MOD_LINEAR_LOCAL;
+    // 2: no modifier attributes (handled via include_modifiers=false)
+    // 3-5: swap XRGB <-> XBGR (SPA BGRx endian ambiguity across drivers)
+    constexpr std::uint32_t XRGB = fourcc_code('X', 'R', '2', '4');  // DRM_FORMAT_XRGB8888
+    constexpr std::uint32_t XBGR = fourcc_code('X', 'B', '2', '4');  // DRM_FORMAT_XBGR8888
+    constexpr std::uint32_t ARGB = fourcc_code('A', 'R', '2', '4');
+    constexpr std::uint32_t ABGR = fourcc_code('A', 'B', '2', '4');
+
+    auto flip_rgb = [](std::uint32_t fourcc) -> std::uint32_t {
+      if (fourcc == XRGB) return XBGR;
+      if (fourcc == XBGR) return XRGB;
+      if (fourcc == ARGB) return ABGR;
+      if (fourcc == ABGR) return ARGB;
+      return fourcc;
+    };
+
+    variants[3].fourcc = flip_rgb(xrgb.fourcc);
+    variants[3].modifier = (xrgb.modifier == DRM_FORMAT_MOD_INVALID) ? DRM_FORMAT_MOD_LINEAR_LOCAL : xrgb.modifier;
+    variants[4].fourcc = flip_rgb(xrgb.fourcc);
+    variants[4].modifier = DRM_FORMAT_MOD_LINEAR_LOCAL;
+    variants[5] = variants[3];
+
+    const char *tags[] = {
+      "as-is+mod",
+      "linear+mod",
+      "as-is+nomod",
+      "flip+mod",
+      "flip+linear",
+      "flip+nomod",
+    };
+    const bool include_mod[] = {true, true, false, true, true, false};
+
+    for (int i = 0; i < 6; ++i) {
+      if (auto rgb = try_import_rgb_texture(egl_display, variants[i], include_mod[i], tags[i])) {
+        return rgb;
+      }
+    }
+
+    BOOST_LOG(error) << "Couldn't import RGB DMA-BUF after retries: fourcc=0x"sv
+                     << util::hex(xrgb.fourcc).to_string_view()
+                     << " modifier="sv << xrgb.modifier
+                     << " size="sv << xrgb.width << "x"sv << xrgb.height
+                     << " pitch="sv << xrgb.pitches[0]
+                     << " offset="sv << xrgb.offsets[0];
+    return std::nullopt;
+  }

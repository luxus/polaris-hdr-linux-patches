+    std::uint64_t buffer_key = 0;
+    uint32_t spa_format = SPA_VIDEO_FORMAT_UNKNOWN;
+
+    void release() {
+      if (is_dmabuf) {
+        for (int i = 0; i < 4; ++i) {
+          if (sd.fds[i] >= 0) {
+            close(sd.fds[i]);
+            sd.fds[i] = -1;
+          }
+        }
+      }
+      cpu_data.clear();
+      is_dmabuf = false;
+      buffer_key = 0;
+    }

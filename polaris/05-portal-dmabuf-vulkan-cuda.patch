+  template<bool XB30>
+  inline __device__ float3 sample_rgb(cudaTextureObject_t srcImage, float x, float y) {
+    if constexpr (XB30) {
+      return xbgr2101010_to_rgb(tex2D<unsigned int>(srcImage, x, y));
+    } else {
+      return bgra_to_rgb(tex2D<float4>(srcImage, x, y));
+    }
+  }

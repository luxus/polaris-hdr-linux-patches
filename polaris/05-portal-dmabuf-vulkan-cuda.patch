+    desc.filterMode = (xbgr2101010 || !linear_filter) ? cudaFilterModePoint : cudaFilterModeLinear;
+    desc.normalizedCoords = false;
+    std::fill_n(std::begin(desc.addressMode), 2, cudaAddressModeClamp);

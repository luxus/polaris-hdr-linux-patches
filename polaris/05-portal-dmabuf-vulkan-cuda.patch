+          activate_fallback("frame import/copy failed"sv);
+          result = convert_mmap(descriptor);
+        }
+        descriptor.reset();
+        active_frame = result == 0;
+        return result;
+      }
+      if (!active_frame) {
+        return convert_blank();
+      }

+  std::optional<cudaTextureObject_t> make_pitch2d_texture(void *dev_ptr, int width, int height, std::size_t pitch_bytes, bool linear_filter) {
+    if (!dev_ptr || width <= 0 || height <= 0 || pitch_bytes < static_cast<std::size_t>(width) * 4) {
+      return std::nullopt;
+    }
+
+    cudaResourceDesc res {};
+    res.resType = cudaResourceTypePitch2D;
+    res.res.pitch2D.devPtr = dev_ptr;
+    res.res.pitch2D.desc = cudaCreateChannelDesc<uchar4>();
+    res.res.pitch2D.width = static_cast<std::size_t>(width);
+    res.res.pitch2D.height = static_cast<std::size_t>(height);
+    res.res.pitch2D.pitchInBytes = pitch_bytes;
+
+    cudaTextureDesc td {};
+    td.readMode = cudaReadModeNormalizedFloat;
+    td.filterMode = linear_filter ? cudaFilterModeLinear : cudaFilterModePoint;
+    td.normalizedCoords = false;
+    std::fill_n(std::begin(td.addressMode), 2, cudaAddressModeClamp);
+
+    cudaTextureObject_t tex = 0;
+    CU_CHECK_OPT(cudaCreateTextureObject(&tex, &res, &td, nullptr), "Couldn't create pitch2D cuda texture");
+    return tex;
+  }
+
+  std::optional<cudaTextureObject_t> make_array_texture(cudaArray_t array, bool linear_filter) {
+    if (!array) {
+      return std::nullopt;
+    }
+
+    cudaResourceDesc res {};
+    res.resType = cudaResourceTypeArray;
+    res.res.array.array = array;
+
+    cudaTextureDesc td {};
+    td.readMode = cudaReadModeNormalizedFloat;
+    td.filterMode = linear_filter ? cudaFilterModeLinear : cudaFilterModePoint;
+    td.normalizedCoords = false;
+    std::fill_n(std::begin(td.addressMode), 2, cudaAddressModeClamp);
+
+    cudaTextureObject_t tex = 0;
+    CU_CHECK_OPT(cudaCreateTextureObject(&tex, &res, &td, nullptr), "Couldn't create array cuda texture");
+    return tex;
+  }
+
+  void destroy_texture(cudaTextureObject_t tex) {
+    if (tex && tex != INVALID_TEXTURE) {
+      CU_CHECK_IGNORE(cudaDestroyTextureObject(tex), "Couldn't destroy cuda texture");
+    }
+  }

       return std::nullopt;
     }
 
+    finish_tex_params(rgb->tex[0]);
+    static bool logged_ok = false;
+    if (!logged_ok) {
+      BOOST_LOG(info) << "EGL import "sv << tag << " OK "
+                      << xrgb.width << "x"sv << xrgb.height
+                      << " fourcc=0x"sv << util::hex(xrgb.fourcc).to_string_view()

From: patch-rebuild <patches@local>
Subject: [PATCH] topic5: LINEAR DmaBuf + EGL→GL→CUDA (no extmem, no mmap)

gamescope DmaBufs reject cuImportExternalMemory on NVIDIA (known). Use
Sunshine-style EGL import (TexStorageEXT/LINEAR) + GL convert + CUDA map.
No mmap fallback — EGL fail means no video.

diff -ruN '--exclude=.git' p-cuda-base/src/platform/linux/cuda.cpp eglfix/src/platform/linux/cuda.cpp
--- a/src/platform/linux/cuda.cpp	2026-07-14 03:39:44.776119317 +0200
+++ b/src/platform/linux/cuda.cpp	2026-07-14 04:03:40.674079484 +0200
@@ -491,10 +491,17 @@
         }
 
         if (!active_rgb) {
+          // gamescope LINEAR DmaBuf: CUDA extmem fails; Sunshine-style EGL→GL→CUDA.
           auto rgb_opt = egl::import_source(display.get(), descriptor.sd);
           if (!rgb_opt) {
+            BOOST_LOG(error) << "CUDA DMABUF: EGL import failed (no mmap fallback)"sv;
             return -1;
           }
+          static bool logged = false;
+          if (!logged) {
+            BOOST_LOG(info) << "CUDA DMABUF: EGL→GL→CUDA path (Sunshine-style; not cuImportExternalMemory)"sv;
+            logged = true;
+          }
 
           auto &entry = rgb_cache[rgb_cache_slot];
           entry.buffer_key = descriptor.dmabuf_buffer_key;

+/// Query PipeWire node for its display resolution from EnumFormat params.
+async fn query_node_size(node_id: u32) -> Option<(u32, u32)> {
+    let output = tokio::process::Command::new("pw-cli")
+        .arg("enum-params")
+        .arg(node_id.to_string())
+        .arg("3")
+        .output()
+        .await
+        .ok()?;
+
+    if !output.status.success() {
+        return None;
+    }
+
+    let stdout = String::from_utf8_lossy(&output.stdout);
+    for line in stdout.lines() {
+        if let Some(rect) = line.trim().strip_prefix("Rectangle ") {
+            if let Some((w_str, h_str)) = rect.split_once("x") {
+                return Some((w_str.trim().parse().ok()?, h_str.trim().parse().ok()?));
+            }
+        }
+    }
+    None
+}
